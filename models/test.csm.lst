0004 TITLE("DRY MATTER PRODUCTION")
0005 
0006 MACRO("""
0007     X, DXDT  = EXPONENTIAL(X0, A, B)
0008     X        = INTGRL(X0, DXTD)
0009     DXDT     = A * (X - B)
0010     """)
0011     
0012 TWT     = WSH + WRT
0013 WSH     = INTGRL(WSHI, GSH)
0014 WRT     = INTGRL(WRTI, GRT)
0015 WSHI    = INCON(50.)
0016 WRTI    = INCON(50.)
0017 GSH     = 0.7 * GTW
0018 GRT     = 0.3 * GTW
0019 GTW     = (GPHOT - MAINT) * CVF
0020 MAINT   = (WSH + WRT) * 0.015
0021 GPHOT   = GPHST * (1. - EXP(-0.7 * LAI))
0022 LAI     = AMIN1(WSH / 500.,  5.)
0023 EX1, R1 = EXPONENTIAL(10., 0.1, 5) 
0024 EX2, R2 = EXPONENTIAL(WRTI, CVF, GPHST / 5.) 
0025 PARAM(
0026     CVF = 0.7, 
0027     GPHST = 400.
0028     )
0029 CONSTANT(
0030     PI = 3.141592,
0031     PI2 = 2 * PI
0032     )      
0033 
0034 TIMER(FINTIM = 100., DELT = 1., PRDEL = 5., OUTDEL = 5.)
0035 METHOD("RECT")
0036 PRINT(TWT, WSH, WRT, GTW)
0037 OUTPUT(TWT)
